# ────────────────────────────────────────────────
# VARIABLES D'ENVIRONNEMENT — Les Poulettes (standalone, sans Strapi)
# Copiez ce fichier en .env.local et remplissez les valeurs
# Ne jamais committer .env.local ou .env.production
# ────────────────────────────────────────────────

# URL du site en production (utilisé pour les redirections Stripe)
SITE_URL=https://lespoulettes.be

# Stripe — Clé publique (côté client, commence par pk_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe — Clé secrète (côté serveur UNIQUEMENT, ne jamais exposer côté client)
STRIPE_SECRET_KEY=sk_live_...

# Stripe — Clé webhook (pour les confirmations de paiement)
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — Email transactionnel (formulaire de contact, confirmations de commande)
# Obtenez une clé sur https://resend.com
RESEND_API_KEY=re_...

# Brevo (ex-Sendinblue) — Newsletter
# Clé API : https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...
# ID de la liste Brevo où stocker les inscrits (visible dans Contacts → Listes)
BREVO_LIST_ID=3

# Google reCAPTCHA v3 — Protection anti-spam du formulaire newsletter
# Créez un site sur https://www.google.com/recaptcha/admin (choisir v3)
RECAPTCHA_SITE_KEY=6Le...
RECAPTCHA_SECRET_KEY=6Le...

# Google Analytics 4 — Measurement ID (ex: G-XXXXXXXXXX)
GA_MEASUREMENT_ID=
